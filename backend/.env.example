# 扣子 Coze stream_run 相关（复制为 .env 后填写）
COZE_REMOTE_ENDPOINT=
COZE_REMOTE_TOKEN=
COZE_PROJECT_ID=
COZE_SESSION_ID=

# 可选：线上前端域名（逗号分隔），用于 CORS；本地 localhost 已默认允许；不要带末尾 /
# CORS_ORIGINS=https://你的前端.onrender.com,https://xxx.vercel.app
# 可选：默认已允许所有 *.vercel.app；若需关闭正则匹配可设为空：CORS_VERCEL_REGEX=
# CORS_VERCEL_REGEX=https://.+\.vercel\.app$
